DATABASE_URL="postgresql://user:password@localhost:5432/padikk"
# Only needed against a pooled connection (e.g. Supabase's transaction pooler on
# DATABASE_URL) — Prisma Migrate needs a direct, non-pooled connection. Omit for
# a plain local Postgres where DATABASE_URL is already direct.
DIRECT_URL="postgresql://user:password@localhost:5432/padikk"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Single-user credentials login — the seed script creates/updates this account
SEED_USER_NAME="Your Name"
SEED_USER_EMAIL="you@example.com"
SEED_USER_PASSWORD="change-me"
